{
    "name": "thinwrap/location",
    "description": "Lightweight, SDK-free PHP wrapper for routing, distance matrix, geocoding, and isochrone across Google, Mapbox, HERE, ESRI, TomTom, and OSRM. Stateless, PSR-18 BYO HTTP client, zero vendor dependencies.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "location",
        "routing",
        "directions",
        "distance-matrix",
        "geocoding",
        "reverse-geocoding",
        "autocomplete",
        "isochrone",
        "polyline",
        "google-maps",
        "google-routes",
        "mapbox",
        "here",
        "esri",
        "arcgis",
        "tomtom",
        "osrm",
        "wrapper",
        "facade",
        "sdk-free",
        "stateless",
        "psr-18",
        "thinwrap"
    ],
    "homepage": "https://github.com/thinwrap/location-php",
    "support": {
        "issues": "https://github.com/thinwrap/location-php/issues",
        "source": "https://github.com/thinwrap/location-php"
    },
    "authors": [
        {
            "name": "Thinwrap maintainers",
            "homepage": "https://github.com/thinwrap"
        }
    ],
    "require": {
        "php": "^8.2",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.0",
        "php-http/discovery": "^1.20"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.1.54",
        "friendsofphp/php-cs-fixer": "^3.95",
        "guzzlehttp/guzzle": "^7.10",
        "guzzlehttp/psr7": "^2.9"
    },
    "autoload": {
        "psr-4": {
            "Thinwrap\\Location\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Thinwrap\\Location\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "phpstan": "phpstan analyse",
        "cs": "php-cs-fixer fix --dry-run --diff",
        "cs-fix": "php-cs-fixer fix",
        "validate-frontmatter": "php scripts/validate-frontmatter.php"
    },
    "config": {
        "sort-packages": true,
        "platform": {
            "php": "8.2.0"
        },
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
